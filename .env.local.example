NEXT_PUBLIC_API_URL=http://localhost:8081
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3001
# Used by src/app/sitemap.ts to build absolute URLs; defaults to https://dmhq.in if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Where "Exit support session" sends a support agent back to; defaults to http://localhost:3002 if unset.
NEXT_PUBLIC_SUPERBOARD_URL=http://localhost:3002
# Must match the backend's DASHBOARD_CLIENT_SECRET exactly (see backend/.env).
# Not a real secret in this app's hands — it's NEXT_PUBLIC_, visible in the
# browser bundle, same as this app's other public config.
NEXT_PUBLIC_CLIENT_ID=dashboard
NEXT_PUBLIC_CLIENT_SECRET=change-me-to-match-backend
